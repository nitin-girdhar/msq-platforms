# hr-service — required environment variables
DATABASE_URL=postgres://hr_svc:HrSvc_Dev2025@localhost:5432/crm
DATABASE_URL_SERVICE=postgres://root_service:CrmSvc_Dev2025@localhost:5432/crm
# hr_svc can read/write only the hr schema + read-only iam/entity/geo (D8) —
# tells @platform/db to skip SET ROLE app_user, which would undo that isolation.
DB_PRODUCT_SCOPED_LOGIN=true
INTERNAL_SERVICE_SECRET=change-me-to-another-long-random-string
HR_SERVICE_PORT=4007
NODE_ENV=development

# Attendance punch-photo storage (local Docker-volume driver by default).
PHOTO_STORAGE_DRIVER=local
PHOTO_STORAGE_DIR=/data/attendance-photos
PHOTO_MAX_BYTES=2097152
