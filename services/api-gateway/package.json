{
  "name": "@crm/api-gateway",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file ../../.env src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "dev:local": "tsx watch --env-file .env src/server.ts"
  },
  "dependencies": {
    "@crm/auth-constants": "workspace:*",
    "@crm/db": "workspace:*",
    "@crm/permissions": "workspace:*",
    "@crm/types": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "fastify": "^5.2.1",
    "jose": "^6.2.3",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
