# ─────────────────────────────────────────────────────────────────────────────
# Shared platform core (msq-core) — identity-service, api-gateway,
# admin-service, communication-service, auth-web, lookup-admin.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection components ──────────────────────────────────────────
# Change these to point at your Postgres instance. docker-compose.yml reads
# these variables too, so one edit here updates everything.
DB_NAME=crm
DB_HOST=localhost
DB_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=Passw0rd

# Docker container name (used by docker-compose as the network hostname)
DB_CONTAINER_NAME=crm-db-server

# Host path for Postgres data (persistent across container recreates)
DB_DATA_PATH=C:/Girdhar/database_files

# Service-role credentials (created by 01_init-db.sql) — shared pool used by
# identity-service, notifications-service (msq-lms) and admin-service.
DB_LEAD_SVC_USER=lead_svc
DB_LEAD_SVC_PASSWORD=LeadSvc_Dev2025
DB_TENANT_SVC_USER=tenant_dash_svc
DB_TENANT_SVC_PASSWORD=TenantSvc_Dev2025
DB_SERVICE_USER=root_service
DB_SERVICE_PASSWORD=CrmSvc_Dev2025

# Per-product DB login roles (P1.2/D8) are NOT used by msq-core services —
# see msq-lms/msq-hrms/msq-todo's own .env.example for
# DB_LMS_SVC_*/DB_HR_SVC_*/DB_TASK_SVC_*.

# ── Composed DATABASE_URLs (local dev — services outside Docker) ─────────────
# These use DB_HOST (localhost). docker-compose overrides them with the
# container hostname so you never need to touch docker-compose.yml.
DATABASE_URL=postgres://lead_svc:LeadSvc_Dev2025@localhost:5432/crm
DATABASE_URL_TENANT=postgres://tenant_dash_svc:TenantSvc_Dev2025@localhost:5432/crm
DATABASE_URL_SERVICE=postgres://root_service:CrmSvc_Dev2025@localhost:5432/crm

# PostgreSQL pool tuning
PG_MAX=10
PG_IDLE_TIMEOUT=30

# PostgreSQL SSL (production)
PG_SSL_MODE=disable             # Force SSL off (local dev, Docker network)
# PG_SSL_CA_PATH=/path/to/ca.pem  # Path to CA certificate file
# PG_SSL_CA=                    # Inline CA certificate (alternative to PG_SSL_CA_PATH)

# JWT
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars
# JWT_SECRET must be the SAME value across all services that verify tokens —
# including every product repo's services.

# Asymmetric JWT signing (RS256). When set, tokens are signed RS256 and other apps
# can verify them via GET /.well-known/jwks.json without any shared secret. When
# unset, signing/verification falls back to the HS256 JWT_SECRET above.
# Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#           openssl rsa -in priv.pem -pubout -out pub.pem
# Store PEMs with literal \n escapes on a single line, or as real multiline values.
# JWT_KID=2026-key-1
# JWT_PRIVATE_KEY=   # identity-service only (signing)
# JWT_PUBLIC_KEY=    # api-gateway + identity-service (verification / JWKS) —
#                     # every product service/app also needs this, see their own .env.example

# Inter-service authentication — gateway injects this header, services reject without it
INTERNAL_SERVICE_SECRET=change-me-to-another-long-random-string

# Server-side pepper for hashing public/partner API keys (iam.api_clients,
# owned by identity-service). Must be identical in api-gateway and
# identity-service. REQUIRED in production. Generate: openssl rand -hex 32
PUBLIC_API_KEY_PEPPER=change-me-public-api-pepper

# ─────────────────────────────────────────────────────────────────────────────
# Service ports (msq-core services only)
# ─────────────────────────────────────────────────────────────────────────────
GATEWAY_PORT=4000
IDENTITY_SERVICE_PORT=4001
COMMUNICATION_SERVICE_PORT=4005
ADMIN_SERVICE_PORT=4006

# ─────────────────────────────────────────────────────────────────────────────
# Internal service URLs (used by api-gateway to proxy to sibling-repo services,
# and by every product web app's next.config.js `/api/*` rewrite target)
# ─────────────────────────────────────────────────────────────────────────────
API_GATEWAY_INTERNAL_URL=http://localhost:4000
IDENTITY_SERVICE_URL=http://localhost:4001
COMMUNICATION_SERVICE_URL=http://localhost:4005
ADMIN_SERVICE_URL=http://localhost:4006

# Product services (msq-lms/msq-hrms/msq-todo) — point these at wherever
# those repos' containers actually run once the parent workspace's Docker
# network is wired (not solved yet, see docker-compose.yml's note). Ports
# below match each product repo's own .env.example defaults.
LEADS_SERVICE_URL=http://localhost:4002
META_SERVICE_URL=http://localhost:4003
NOTIFICATIONS_SERVICE_URL=http://localhost:4004
HR_SERVICE_URL=http://localhost:4007
TASKS_SERVICE_URL=http://localhost:4008

# ─────────────────────────────────────────────────────────────────────────────
# Communication service (email + WhatsApp)
# ─────────────────────────────────────────────────────────────────────────────
# SMTP / Email (all required for email to be enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Your App Name

# WhatsApp via Interakt (required for WhatsApp to be enabled)
INTERAKT_API_KEY=your-interakt-api-key
# INTERAKT_API_BASE_URL=https://api.interakt.ai/v1/public/

# ─────────────────────────────────────────────────────────────────────────────
# Identity service (auth + users)
# ─────────────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# Minimum length enforced for new/changed passwords (identity-service policy).
PASSWORD_MIN_LENGTH=12

# ─────────────────────────────────────────────────────────────────────────────
# App environment
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Web apps (Next.js) — auth-web + lookup-admin live in msq-core.
#   auth-web  → auth.app.com  (login / change-password / select-branch)
# lms-web/hr-web/todo-web live in their own product repos (see that repo's
# .env.example) but share this same SSO cookie/origin config.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# JWT_SECRET (HS256) OR JWT_PUBLIC_KEY (RS256) must be set for middleware.ts Edge
# JWT validation. Product apps should carry JWT_PUBLIC_KEY, never JWT_SECRET.

# Must match PASSWORD_MIN_LENGTH above — drives the password-strength checklist
# shown in the change-password / reset-password forms.
NEXT_PUBLIC_PASSWORD_MIN_LENGTH=12

# SSO cookie scope — the parent domain shared by every product subdomain, so one
# login (at auth.app.com) authenticates all of lms./hr./todo. Leading dot.
# Leave UNSET in single-host local dev (localhost can't set a parent-domain
# cookie) → host-only cookie, single app only.
# COOKIE_DOMAIN=.app.com
# Set true whenever COOKIE_DOMAIN is set (SSO requires HTTPS in real deployments).
COOKIE_SECURE=false

# Cross-app SSO origins (scheme + host). Product apps redirect unauthenticated
# users to NEXT_PUBLIC_AUTH_URL/login and render a product switcher linking the
# others. auth-web validates its post-login callbackUrl against this set.
# Local single-host dev (per-port) defaults:
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_LMS_URL=http://localhost:3001
NEXT_PUBLIC_HR_URL=http://localhost:3002
NEXT_PUBLIC_TASK_URL=http://localhost:3003
# Subdomain deployment (with the reverse proxy) would instead be, e.g.:
# NEXT_PUBLIC_AUTH_URL=https://auth.app.com
# NEXT_PUBLIC_LMS_URL=https://lms.app.com
# NEXT_PUBLIC_HR_URL=https://hr.app.com
# NEXT_PUBLIC_TASK_URL=https://todo.app.com

# Gateway
WEB_URL=http://localhost:3000
