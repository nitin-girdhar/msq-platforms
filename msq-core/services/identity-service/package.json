    "@platform/db": "workspace:*",
    "@platform/service-auth": "workspace:*",
    "@platform/types": "workspace:*",
    "@platform/validation": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "zod": "^3.22.0",
    "@fastify/cookie": "^11.0.2",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.10",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
