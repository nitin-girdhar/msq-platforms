{
  "name": "@crm/identity-service",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist"
  ],
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file ../../../.env src/server.ts",
