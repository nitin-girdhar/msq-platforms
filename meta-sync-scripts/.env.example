# meta-sync-scripts — required environment variables
#
# Same DATABASE_URL_SERVICE / META_ENCRYPTION_KEY the Node meta-conversion-api
# service uses (see services/meta-conversion-api/.env.example). These scripts
# make no HTTP calls to any internal CRM service — DB access only, plus
# direct calls to graph.facebook.com.

DATABASE_URL_SERVICE=postgres://root_service:CrmSvc_Dev2025@localhost:5432/crm

# Must match the Node service's META_ENCRYPTION_KEY exactly, or decrypting
# ext.meta_tenant_config.app_secret/access_token will fail. 64 hex chars or
# 44-char base64 (32 bytes). Leave unset only if the Node service also has no
# key configured (dev-only — credentials stored as plaintext).
META_ENCRYPTION_KEY=

# Default Graph API version used when a tenant row doesn't specify one.
META_GRAPH_API_VERSION=v21.0

LOG_LEVEL=INFO
